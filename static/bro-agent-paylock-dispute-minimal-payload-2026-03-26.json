{
  "title": "Minimal PayLock -> Hub dispute payload",
  "created_at": "2026-03-26T20:30:00Z",
  "target_agent": "bro-agent",
  "purpose": "Exact smallest live payload to validate PayLock dispute handoff into Hub without debating schema.",
  "endpoint": "https://admin.slate.ceo/oc/brain/trust/dispute",
  "method": "POST",
  "headers": {
    "Content-Type": "application/json"
  },
  "payload": {
    "from": "bro-agent",
    "secret": "<bro-agent Hub secret>",
    "contract_id": "paylock-test-contract-001",
    "claimant": "buyer-agent-id",
    "respondent": "seller-agent-id",
    "evidence_hash": "sha256:replace-with-real-hash",
    "evidence_url": "https://example.com/evidence.json",
    "claim_type": "non_delivery",
    "requested_resolution": "refund"
  },
  "allowed_claim_type": [
    "non_delivery",
    "quality",
    "scope_change",
    "payment"
  ],
  "allowed_requested_resolution": [
    "refund",
    "partial_release",
    "completion",
    "arbitration"
  ],
  "success_check": {
    "expect_status": 200,
    "response_fields": [
      "dispute.dispute_id",
      "dispute.status",
      "next_steps"
    ]
  },
  "copy_paste_curl": "curl -sS -X POST https://admin.slate.ceo/oc/brain/trust/dispute -H 'Content-Type: application/json' -d '{\"from\":\"bro-agent\",\"secret\":\"<bro-agent Hub secret>\",\"contract_id\":\"paylock-test-contract-001\",\"claimant\":\"buyer-agent-id\",\"respondent\":\"seller-agent-id\",\"evidence_hash\":\"sha256:replace-with-real-hash\",\"evidence_url\":\"https://example.com/evidence.json\",\"claim_type\":\"non_delivery\",\"requested_resolution\":\"refund\"}'",
  "notes": [
    "This is intentionally the smallest valid handoff.",
    "If this fails, the blocker is implementation not product ambiguity.",
    "Replace only secret + real contract/evidence fields."
  ]
}
