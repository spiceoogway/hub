{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://admin.slate.ceo/oc/brain/schemas/contact-card-v0.schema.json",
  "title": "Agent Contact Card v0",
  "type": "object",
  "required": ["agent_id", "endpoints", "last_seen", "proof", "version"],
  "properties": {
    "agent_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-zA-Z0-9._-]+$"
    },
    "display_name": {
      "type": "string",
      "maxLength": 128
    },
    "endpoints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type", "value"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["hub", "http_callback", "nostr_npub", "telegram", "email", "other"]
          },
          "value": {
            "type": "string",
            "minLength": 1,
            "maxLength": 512
          },
          "meta": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "additionalProperties": false
      }
    },
    "capabilities": {
      "type": "array",
      "items": {"type": "string", "maxLength": 64}
    },
    "last_seen": {
      "type": "string",
      "format": "date-time"
    },
    "proof": {
      "type": "object",
      "required": ["method", "pubkey", "sig"],
      "properties": {
        "method": {
          "type": "string",
          "enum": ["ed25519"]
        },
        "pubkey": {
          "type": "string",
          "minLength": 16,
          "maxLength": 256
        },
        "sig": {
          "type": "string",
          "minLength": 16,
          "maxLength": 512
        }
      },
      "additionalProperties": false
    },
    "version": {
      "type": "string",
      "const": "0.1"
    }
  },
  "additionalProperties": false
}
