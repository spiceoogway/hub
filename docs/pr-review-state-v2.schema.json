{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://admin.slate.ceo/oc/brain/schemas/pr-review-state-v2.schema.json",
  "title": "PR Review State v2 — Blockers Reducer",
  "type": "object",
  "required": ["schema_version", "pr", "blockers", "reducer_metadata"],
  "description": "GitHub PR state → normalized blockers[]. Focus: semantic blocking detection for human review signals.",
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "2.0",
      "description": "Schema version. MUST be '2.0' for this spec."
    },
    "pr": {
      "type": "object",
      "required": ["repo", "number", "url", "head_sha"],
      "properties": {
        "repo": {
          "type": "string",
          "pattern": "^[^/]+/[^/]+$",
          "examples": ["owner/repo"]
        },
        "number": {"type": "integer", "minimum": 1},
        "url": {"type": "string", "format": "uri"},
        "head_sha": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$",
          "description": "Current head commit SHA. Blockers MUST be anchored to this SHA."
        },
        "title": {"type": "string", "maxLength": 512},
        "state": {"type": "string", "enum": ["open", "closed", "merged"]},
        "draft": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "blockers": {
      "type": "array",
      "description": "Normalized blockers. Empty array = no blockers detected. NOT 'unknown'.",
      "items": {
        "type": "object",
        "required": ["id", "kind", "source", "blocking_score", "formal_blocking", "semantic_blocking", "normalized_text", "resolved", "head_sha"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Stable hash of blocking condition. Format: kind:source:index:SHA[:detail]. Used for deduplication and staleness detection.",
            "examples": ["changes_requested:review:0:a1b2c3", "blocking_comment:thread:2:d4e5f6"]
          },
          "kind": {
            "type": "string",
            "enum": ["changes_requested", "blocking_comment", "failed_check", "conflict", "draft", "merge_conflict", "other"],
            "description": "Categorical type of blocker."
          },
          "source": {
            "type": "string",
            "enum": ["review", "comment_thread", "check", "commit", "meta", "ci"],
            "description": "Where the blocking signal originated."
          },
          "blocking_score": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0,
            "description": "Confidence that this condition blocks merge. 1.0 = definitive blocker."
          },
          "formal_blocking": {
            "type": "boolean",
            "description": "True: GitHub API blocks merge by default. False: this is a semantic signal, not a hard gate."
          },
          "semantic_blocking": {
            "type": "boolean",
            "description": "True: this functionally blocks merge even if formally not. e.g. unresolved blocking-comment thread on an approved PR.",
            "notes": {
              "type": "object",
              "description": "Trust criteria for semantic_blocking. MUST include at least one of these signals to be trustworthy.",
              "properties": {
                "signal_types": {
                  "type": "array",
                  "items": {"type": "string"},
                  "minItems": 1,
                  "description": "What signals drove the semantic_blocking=true call. Required: at least 1."
                },
                "reviewer_trust": {
                  "type": "string",
                  "enum": ["untrusted", "contributor", "maintainer", "explicit_approval"],
                  "description": "Trust level of the reviewer raising the signal."
                },
                "thread_resolution": {
                  "type": "string",
                  "enum": ["unresolved", "resolved_by_author", "resolved_by_reviewer", "never_resolved"],
                  "description": "Current resolution state of comment thread, if applicable."
                },
                "keyword_signal": {
                  "type": "boolean",
                  "description": "True if blocking keywords (e.g. '🚫', 'BLOCKING', 'must-fix', 'do not merge') were detected in the triggering comment."
                },
                "age_days": {
                  "type": "number",
                  "description": "Days since blocking signal was raised. High age + unresolved = higher confidence."
                },
                "reaffirmed_after_push": {
                  "type": "boolean",
                  "description": "True if reviewer explicitly reaffirmed the blocking signal after the last push."
                }
              },
              "required": ["signal_types"]
            }
          },
          "normalized_text": {
            "type": "string",
            "maxLength": 256,
            "description": "Short canonical description of the blocking condition."
          },
          "last_activity": {
            "type": "string",
            "format": "date-time",
            "description": "ISO timestamp of last activity on this blocking signal."
          },
          "resolved": {
            "type": "boolean",
            "description": "True if this blocker has been explicitly resolved."
          },
          "resolution_hint": {
            "type": "string",
            "maxLength": 256,
            "description": "Short hint on how to resolve this blocker, if resolved=false."
          },
          "head_sha": {
            "type": "string",
            "pattern": "^[0-9a-f]{40}$",
            "description": "SHA this blocker was evaluated against. MUST match pr.head_sha or pr.head_sha of the evaluation."
          },
          "stale": {
            "type": "boolean",
            "description": "True if this blocker was raised against a prior head_sha and has NOT been reaffirmed on current head_sha."
          },
          "metadata": {
            "type": "object",
            "description": "Source-specific raw fields kept for auditability.",
            "properties": {
              "review_id": {"type": "string"},
              "comment_thread_id": {"type": "string"},
              "check_run_id": {"type": "string"},
              "reviewer_login": {"type": "string"},
              "check_name": {"type": "string"},
              "check_status": {"type": "string", "enum": ["success", "failure", "pending", "cancelled"]}
            }
          }
        },
        "additionalProperties": false
      }
    },
    "reducer_metadata": {
      "type": "object",
      "required": ["evaluated_at", "head_sha", "raw_state_version"],
      "properties": {
        "evaluated_at": {"type": "string", "format": "date-time"},
        "head_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "raw_state_version": {"type": "string", "description": "Version/timestamp of the raw GitHub state snapshot used."},
        "blocker_count": {"type": "integer", "minimum": 0},
        "has_formal_blockers": {"type": "boolean"},
        "has_semantic_blockers": {"type": "boolean"},
        "all_blockers_stale": {"type": "boolean"},
        "reducer_version": {"type": "string"}
      }
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "schema_version": "2.0",
      "pr": {
        "repo": "handsdiff/pr-review-state",
        "number": 42,
        "url": "https://github.com/handsdiff/pr-review-state/pull/42",
        "head_sha": "a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2",
        "title": "feat: add blockers reducer",
        "state": "open",
        "draft": false
      },
      "blockers": [
        {
          "id": "blocking_comment:thread:0:a1b2c3",
          "kind": "blocking_comment",
          "source": "comment_thread",
          "blocking_score": 0.85,
          "formal_blocking": false,
          "semantic_blocking": true,
          "normalized_text": "Unresolved blocking comment from maintainer after approval",
          "last_activity": "2026-03-07T06:05:00Z",
          "resolved": false,
          "resolution_hint": "Resolve the comment thread or get reviewer reaffirmation after latest push",
          "head_sha": "a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2",
          "stale": false,
          "notes": {
            "signal_types": ["thread_resolution", "reviewer_trust", "keyword_signal"],
            "reviewer_trust": "maintainer",
            "thread_resolution": "unresolved",
            "keyword_signal": true,
            "age_days": 2.3,
            "reaffirmed_after_push": false
          },
          "metadata": {
            "comment_thread_id": "CT_123",
            "reviewer_login": "maintainer-x"
          }
        }
      ],
      "reducer_metadata": {
        "evaluated_at": "2026-03-07T06:10:00Z",
        "head_sha": "a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2",
        "raw_state_version": "2026-03-07T06:09:00Z",
        "blocker_count": 1,
        "has_formal_blockers": false,
        "has_semantic_blockers": true,
        "all_blockers_stale": false,
        "reducer_version": "2.0.0"
      }
    },
    {
      "schema_version": "2.0",
      "pr": {
        "repo": "handsdiff/pr-review-state",
        "number": 43,
        "url": "https://github.com/handsdiff/pr-review-state/pull/43",
        "head_sha": "b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3",
        "title": "chore: update deps",
        "state": "open",
        "draft": false
      },
      "blockers": [],
      "reducer_metadata": {
        "evaluated_at": "2026-03-07T06:10:00Z",
        "head_sha": "b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3",
        "raw_state_version": "2026-03-07T06:09:00Z",
        "blocker_count": 0,
        "has_formal_blockers": false,
        "has_semantic_blockers": false,
        "all_blockers_stale": false,
        "reducer_version": "2.0.0"
      }
    }
  ]
}
